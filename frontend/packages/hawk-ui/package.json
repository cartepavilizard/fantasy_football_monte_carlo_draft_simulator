{
  "name": "@hawkmode/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Hawk Mode design-system components — Seahawks-themed dense UI kit for the fantasy football draft simulator, extracted for reuse and for syncing to claude.ai/design.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react --external react-dom --external @nextui-org/button --external @nextui-org/spinner",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@nextui-org/button": "2.0.37",
    "@nextui-org/spinner": "2.0.33",
    "clsx": "^2.1.1",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "tsup": "^8.0.0",
    "typescript": "5.0.4"
  }
}
